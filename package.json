{
    "name": "@nitinkumar16/backendkit",
    "version": "1.0.4",
    "description": "Production-ready Node.js/Express backend starter kit with auth, security, validation, and config.",
    "author": "Nitin Kumar <nitinkumar16072005@gmail.com>",
    "type": "module",
    "license": "MIT",
    "packageManager": "npm@11.5.2",
    "sideEffects": false,
    "publishConfig": {
        "access": "public"
    },
    "main": "./dist/index.js",
    "module": "./dist/index.js",
    "types": "./types/index.d.ts",
    "exports": {
        ".": {
            "types": "./types/index.d.ts",
            "import": "./dist/index.js"
        }
    },
    "files": [
        "dist",
        "src",
        "types",
        "README.md",
        "CHANGELOG.md",
        "LICENSE"
    ],
    "scripts": {
        "lint": "eslint .",
        "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js --runInBand",
        "test:ci": "npm run coverage",
        "test:coverage": "node --experimental-vm-modules node_modules/jest/bin/jest.js --runInBand --coverage",
        "coverage": "node --experimental-vm-modules node_modules/jest/bin/jest.js --runInBand --coverage",
        "build": "tsup",
        "prepublishOnly": "npm run lint && npm test && npm run build"
    },
    "engines": {
        "node": ">=18"
    },
    "keywords": [
        "backend",
        "starter",
        "express",
        "middleware",
        "auth",
        "jwt",
        "security",
        "validation",
        "plugin",
        "logger",
        "configuration",
        "node"
    ],
    "repository": {
        "type": "git",
        "url": "git+https://github.com/nitin16112004/node-backend-starter.git"
    },
    "bugs": {
        "url": "https://github.com/nitin16112004/node-backend-starter/issues"
    },
    "homepage": "https://github.com/nitin16112004/node-backend-starter",
    "peerDependencies": {
        "express": "^4.18.0"
    },
    "dependencies": {
        "cors": "^2.8.5",
        "csrf-csrf": "^4.0.3",
        "csurf": "^1.11.0",
        "express-rate-limit": "^7.1.5",
        "helmet": "^7.0.0",
        "jsonwebtoken": "^9.0.0",
        "xss": "^1.0.15",
        "xss-clean": "^0.1.4",
        "zod": "^3.24.0"
    },
    "devDependencies": {
        "eslint": "^8.57.1",
        "jest": "^29.7.0",
        "prettier": "^3.3.3",
        "rimraf": "^6.1.3",
        "tsup": "^8.3.0",
        "typescript": "^6.0.3"
    }
}
